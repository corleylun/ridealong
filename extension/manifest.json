{
  "manifest_version": 2,
  "name": "Firefox MCP Bridge",
  "version": "0.1.0",
  "description": "Lets a local AI agent drive THIS Firefox (navigate/read/query) via a localhost MCP bridge. Real browser, real session, no CDP.",
  "permissions": ["tabs", "activeTab", "storage", "<all_urls>"],
  "background": { "scripts": ["background.js"], "persistent": true },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Firefox MCP Bridge"
  },
  "browser_specific_settings": {
    "gecko": { "id": "firefox-mcp@local", "strict_min_version": "115.0" }
  }
}
